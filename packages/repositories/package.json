{
  "dependencies": {
    "execa": "catalog:"
  },
  "description": "Reusable repository adapters for agpr",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./coverage-files": {
      "import": "./dist/coverage-files.js",
      "types": "./dist/coverage-files.d.ts"
    },
    "./file-system": {
      "import": "./dist/file-system.js",
      "types": "./dist/file-system.d.ts"
    },
    "./git": {
      "import": "./dist/git.js",
      "types": "./dist/git.d.ts"
    },
    "./github": {
      "import": "./dist/github.js",
      "types": "./dist/github.d.ts"
    }
  },
  "files": [
    "dist/**/*"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "name": "@agpr/repositories",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "type": "module",
  "types": "dist/index.d.ts",
  "version": "0.0.3"
}
