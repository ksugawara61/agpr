{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@ksugawara61/agpr-repositories": [
        "./packages/repositories/src/index.ts"
      ],
      "@ksugawara61/agpr-repositories/*": [
        "./packages/repositories/src/*.ts"
      ]
    }
  },
  "exclude": ["node_modules", "**/dist", "**/*.test.ts"],
  "include": ["apps/*/src/**/*.ts", "packages/*/src/**/*.ts"]
}
