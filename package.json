{
  "description": "workspace for the agpr CLI and reusable packages",
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "esbuild": "catalog:",
    "knip": "catalog:",
    "lefthook": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "license": "MIT",
  "name": "agpr-workspace",
  "packageManager": "pnpm@11.1.0+sha512.0c44e842e5686b2c061a81adda8b2258bd8818e9704b2cf2c63d56b931a7b2e910092e085027003b96ca3911ab56a07f6df5abaed2be9925034cdd686a535b14",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "coverage": "pnpm test",
    "fmt": "biome check --write .",
    "knip": "knip",
    "lint": "biome lint .",
    "prepare": "bash scripts/install-lefthook.sh",
    "test": "vitest run --coverage",
    "typecheck": "turbo run typecheck"
  },
  "version": "0.0.2"
}
