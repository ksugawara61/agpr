{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreBinaries": ["gh", "diff-coverage"],
  "workspaces": {
    "apps/agpr": {
      "ignoreDependencies": ["execa"],
      "paths": {
        "@agpr/repositories": [
          "../../packages/repositories/src/index.ts"
        ],
        "@agpr/repositories/*": [
          "../../packages/repositories/src/*.ts"
        ]
      },
      "project": ["src/**/*.ts"]
    },
    "packages/repositories": {
      "project": ["src/**/*.ts"]
    }
  }
}
