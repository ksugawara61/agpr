{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.claude/hooks/install_pkgs.sh\"",
            "statusMessage": "Installing dependencies and setting up the environment..."
          }
        ]
      }
    ]
  }
}
