prefix_rule(pattern=["pnpm", "build"], decision="allow")
prefix_rule(pattern=["pnpm", "fmt"], decision="allow")
prefix_rule(pattern=["pnpm", "test"], decision="allow")
prefix_rule(pattern=["pnpm", "lint"], decision="allow")
prefix_rule(pattern=["pnpm", "typecheck"], decision="allow")
prefix_rule(pattern=["pnpm", "install"], decision="allow")
prefix_rule(pattern=["npx", "@ksugawara61/agpr@latest"], decision="allow")
prefix_rule(pattern=["npm"], decision="forbidden")
prefix_rule(pattern=["rm"], decision="forbidden")
